# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB Atlas connection string (optional — app works without it using local sessions)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/neurosense_db?retryWrites=true&w=majority

# Flask secret key — change this to a long random string in production
NEUROSENSE_SECRET=change-me-to-a-random-secret

# Optional overrides
# PORT=5000
# FLASK_DEBUG=false
# MRI_MODEL_PATH=ml/models/mri_model.pt
